# GSD planning docs (local only)
.planning/*
!.planning/codebase/

# GSD Framework-Dateien (installiert von gsd-core, nicht committen)
.github/gsd-core/
.github/gsd-file-manifest.json
.github/gsd-install-state.json
.github/gsd-migration-journal/
.github/.gsd-profile
.github/hooks/
.github/scripts/
.github/skills/gsd-*/
.github/agents/gsd-*.agent.md

# VS Code / Electron debug output
debug.log
*.log

# AL-Entwicklungsartefakte (gehören in AL-Projekt-Repos außerhalb des Framework-Repos)
.alpackages/
.snapshots/
.altestrunner/

# AL kompilierte Binaries
*.app

# AL Workflow Session-State (per-Entwickler, nicht git-getrackt)
.planning/al-workflow/
